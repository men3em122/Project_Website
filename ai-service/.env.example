# ─── Offline AI Service Configuration ────────────────────────────────────────
# All models run locally. No internet connection is needed at runtime.
#
# Model paths (override only if you stored models elsewhere):
#SAM2_CHECKPOINT=checkpoints/sam2.1_hiera_large.pt
#SAM2_CONFIG=configs/sam2.1/sam2.1_hiera_l.yaml
#YOLO_WEIGHTS=weights of yolo model/best.pt
#
# SegFormer: place pytorch_model.bin (or model.safetensors) inside local_segformer/
# alongside the existing config.json and preprocessor_config.json.
# To download the weights once (requires internet, do this once on a connected machine):
#   python -c "
#   from transformers import SegformerForSemanticSegmentation, AutoImageProcessor
#   m = SegformerForSemanticSegmentation.from_pretrained('wu-pr-gw/segformer-b2-finetuned-with-LoveDA')
#   p = AutoImageProcessor.from_pretrained('wu-pr-gw/segformer-b2-finetuned-with-LoveDA')
#   m.save_pretrained('local_segformer')
#   p.save_pretrained('local_segformer')
#   "
#
# Set to the Hugging Face model ID ONLY if you explicitly want an online download:
#SEGFORMER_MODEL=wu-pr-gw/segformer-b2-finetuned-with-LoveDA

YOLO_CONF_THRESHOLD=0.10
PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

# Blocks all Hugging Face network calls at runtime (set by main.py automatically).
# Override to 0 only if you want to allow downloads.
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
