# Paths to the model files. All of these are OPTIONAL — by default the
# service looks inside the local folders (see README):
#   checkpoints/sam2.1_hiera_large.pt
#   weights of yolo model/best.pt
#   local_segformer/  (falls back to downloading from Hugging Face)
# Only set these to point somewhere else.
#SAM2_CHECKPOINT=checkpoints/sam2.1_hiera_large.pt
#SAM2_CONFIG=configs/sam2.1/sam2.1_hiera_l.yaml
#YOLO_WEIGHTS=weights of yolo model/best.pt

SEGFORMER_MODEL=wu-pr-gw/segformer-b2-finetuned-with-LoveDA
YOLO_CONF_THRESHOLD=0.10

PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
